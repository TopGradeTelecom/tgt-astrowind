---
import DowntimeCalculatorWidget from '~/components/common/DowntimeCalculator.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Downtime Calculator',
};
---

<Layout metadata={metadata}>
  <section class="max-w-5xl mx-auto px-4 md:px-6 py-16 md:py-20">
    <p class="text-sm font-semibold tracking-[0.08em] uppercase text-primary">Planning Tool</p>
    <h1 class="mt-2 text-3xl md:text-4xl font-bold tracking-tight">Downtime Calculator</h1>
    <p class="mt-3 text-muted max-w-3xl">
      Estimate the annual financial impact of downtime from phone outages, email disruptions, computer issues, and
      other IT and communications interruptions.
    </p>
    <div class="mt-8">
      <DowntimeCalculatorWidget />
    </div>
  </section>
</Layout>
