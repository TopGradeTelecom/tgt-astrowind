---
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';
import { headerData } from '~/navigation';

const metadata = {
  title: 'About us',
};

const getStartedLink = headerData.actions?.find((action) => action.text === 'Get Started')?.href;
---

<Layout metadata={metadata}>
  <Hero
    tagline="About us"
    title="Top Grade is more than a name. It is our standard."
    subtitle="We are a locally owned and operated Southern Colorado team delivering managed IT, networking, and structured cabling solutions built for reliability and long-term value."
    image={{
      src: '~/assets/images/shutterstock_661113826-optimized.jpg',
      alt: 'Engineers reviewing data center infrastructure and cabling systems',
    }}
  />

  <section class="max-w-5xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <div class="rounded-2xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-6 md:p-10">
      <div class="mx-auto max-w-4xl space-y-8">
        <div class="space-y-3">
          <h2 class="m-0 text-lg font-semibold text-default leading-tight">Locally owned in Southern Colorado</h2>
          <p class="m-0 text-muted leading-relaxed">
          We are proud to be a locally owned and operated business serving Southern Colorado. What started as a
          one-man operation has grown into a team of skilled technicians with over 30 years of combined experience in
          technical support and networking. Our adaptability and problem-solving approach help us deliver exceptional
          results, even when it means going the extra mile.
          </p>
        </div>
        <div class="space-y-3 pt-3 md:pt-4">
          <h2 class="m-0 text-lg font-semibold text-default leading-tight">Built for reliability and long-term value</h2>
          <p class="m-0 text-muted leading-relaxed">
          We specialize in managed IT services, including computer repair, networking, and structured data cabling.
          Over the years, we have corrected countless subpar setups and strengthened our expertise across multiple
          disciplines. Instead of cutting corners, we focus on reliable, future-ready, low-maintenance solutions
          tailored to your environment.
          </p>
        </div>
        <div class="space-y-3 pt-3 md:pt-4">
          <h2 class="m-0 text-lg font-semibold text-default leading-tight">Support for businesses and individuals</h2>
          <p class="m-0 text-muted leading-relaxed">
          Whether you are a small business that needs dependable IT support or an individual facing a tech issue, we
          can help. From managing complex networks to repairing broken laptops, we deliver efficient, effective service
          that keeps your technology running smoothly.
          </p>
        </div>
        <div class="space-y-3 pt-3 md:pt-4">
          <h2 class="m-0 text-lg font-semibold text-default leading-tight">Let us handle the tech</h2>
          <p class="m-0 text-muted leading-relaxed">
          Do not let technical challenges slow your business down. Let us handle your day-to-day IT needs so you can
          stay focused on what you do best. Contact us to schedule an appointment and experience the Top Grade
          difference.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Features2
    title="What We Deliver"
    subtitle="Practical IT services designed for stability, maintainability, and long-term business continuity."
    columns={3}
    items={[
      {
        title: 'Managed IT Services',
        description: 'Proactive support, monitoring, and maintenance to reduce disruptions and improve uptime.',
        icon: 'tabler:settings',
      },
      {
        title: 'Networking & Repair',
        description:
          'Design, troubleshooting, and remediation for business networks, endpoints, and day-to-day technical issues.',
        icon: 'tabler:network',
      },
      {
        title: 'Structured Data Cabling',
        description: 'Standards-based cabling work that is clean, scalable, and easier to support over time.',
        icon: 'tabler:plug-connected',
      },
    ]}
  />

  <Features2
    title="Our locations"
    tagline="Find us"
    columns={2}
    items={[
      {
        title: 'Pueblo HQ',
        description: '2001 Oakshire Lane, Suite C, Pueblo, CO 81001',
      },
      {
        title: 'Denver Office',
        description: 'Denver Metro, CO',
      },
    ]}
  />

  <Features2
    title="Support Channels"
    tagline="Contact us"
    columns={2}
    items={[
      {
        title: 'Technical support',
        description:
          'For incidents, outages, and troubleshooting:<br /><br />Ticket Email: <a href="mailto:support@topgradetech.com" class="underline">support@topgradetech.com</a><br />Toll-Free: <a href="tel:+18559470067" class="underline">(855) 947-0067</a>',
        icon: 'tabler:headset',
      },
      {
        title: 'Sales and appointments',
        description:
          'Pueblo HQ: <a href="tel:+17197660944" class="underline">(719) 766-0944</a><br />Denver Office: <a href="tel:+17208807521" class="underline">(720) 880-7521</a>',
        icon: 'tabler:calendar-event',
        ...(getStartedLink
          ? {
              callToAction: {
                text: 'Get Started',
                href: getStartedLink,
                target: '_blank',
                variant: 'primary',
              },
            }
          : {}),
      },
    ]}
  />
</Layout>
