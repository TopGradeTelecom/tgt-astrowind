---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Top Grade Tech -- Premier US-Based IT, Networks & Telecom Solutions',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Contact Us',
        href: '#contact',
      },
      { text: 'Learn more', href: '#features' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Top Grade Tech Hero Image' }}
  >
    <Fragment slot="title">
      Premier <span class="hidden xl:inline">US-Based</span>
      <span class="text-accent dark:text-white"> Customer Support</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">Top Grade Tech</span> delivers reliability through simplicity with exceptional managed IT, networks, and telecom solutions.</span
      >
      <span class="block mb-1 sm:hidden font-bold text-blue-600">Top Grade Tech: Reliability Through Simplicity.</span>
      Trusted by businesses across the US for managed IT services, premium hardware solutions, and fully managed telecom services with unrivaled support.
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="Our Promise:" description="Reliability through Simplicity" />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Why Top Grade Tech"
    title="What Sets Us Apart"
    subtitle="Industry-leading expertise backed by exceptional US-based customer support and comprehensive solutions tailored to your business needs."
    items={[
      {
        title: 'Exceptional US-Based Support',
        description:
          'Talk to real US-based technicians who understand your business. No outsourcing, no language barriers -- just dedicated local support.',
        icon: 'tabler:headset',
      },
      {
        title: 'Premium Hardware Solutions',
        description:
          'Access to enterprise-grade hardware and equipment sourced to ensure maximum reliability and performance for your operations.',
        icon: 'tabler:server-2',
      },
      {
        title: 'Unrivaled System Reliability',
        description:
          'Our proactive monitoring and preventive maintenance ensure your systems stay up and running 24/7/365 with minimal downtime.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Intuitive and Tailored VoIP Phones',
        description:
          'Purpose-built communication solutions that are simple to use yet powerful enough to meet enterprise demands.',
        icon: 'tabler:phone',
      },
      {
        title: 'Complimentary Staff Training',
        description:
          'We invest in your team with comprehensive training programs to maximize adoption and efficiency of new systems.',
        icon: 'tabler:book',
      },
      {
        title: 'Fully Managed Telecom Solutions',
        description:
          'End-to-end telecom management so you can focus on your business while we handle the infrastructure and support.',
        icon: 'tabler:network',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Our Approach"
    title="Built on Trust and Expertise"
    items={[
      {
        title: 'Local Support Team',
        description:
          'Our US-based technicians are available to provide personalized assistance and strategic guidance for your IT infrastructure.',
      },
      {
        title: 'Proactive Maintenance',
        description:
          'We monitor your systems continuously to identify and resolve potential issues before they impact your business.',
      },
      {
        title: 'Scalable Solutions',
        description:
          "Whether you're a small business or a growing enterprise, our solutions grow with you without disruption.",
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Top Grade Tech Solutions',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Reliability Through Simplicity</h3>
      We believe the best technology is the technology that works seamlessly, requires minimal management, and delivers maximum peace of mind.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Managed IT Services',
        description: 'Comprehensive IT support and management, keeping your systems running smoothly so you can focus on growing your business.',
      },
      {
        title: 'Network Infrastructure',
        description:
          'Robust and secure network solutions designed to support your operations, with 24/7 monitoring and proactive maintenance.',
      },
      {
        title: 'Telecom Services',
        description:
          'Reliable communication solutions tailored to your needs, from VoIP to connectivity services that keep your team connected.',
      },
      {
        title: 'Security & Compliance',
        description:
          'Protect your business with enterprise-grade security measures and ensure compliance with industry standards and regulations.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600132806370-bf17e65e942f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2194&q=80',
      alt: 'Top Grade Tech Services',
    }}
  >
    <Fragment slot="content">Enterprise-grade solutions, simplified for your business.</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    tagline="Our Services"
    title="Complete IT & Telecom Solutions"
    items={[
      {
        title: 'Exceptional US-Based Support',
        description:
          'Direct access to knowledgeable US-based technicians who understand your business and provide personalized solutions.',
      },
      {
        title: 'Premium Hardware Solutions',
        description:
          'Enterprise-quality equipment and infrastructure designed for reliability, performance, and longevity.',
      },
      {
        title: 'Unrivaled System Reliability',
        description:
          '24/7 monitoring, proactive maintenance, and rapid response times to ensure your systems stay operational.',
      },
      {
        title: 'Fully Managed Telecom',
        description: 'Complete management of your communication infrastructure so you can focus on what matters -- growing your business.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Top Grade Tech Enterprise Solutions',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Enterprise-Grade Solutions</h3>
      Tailored IT, network, and telecom services designed for businesses that demand reliability and performance.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Features2 Widget - Service Offerings *** -->

  <Features2
    title="Why Choose Top Grade Tech"
    subtitle="Industry-leading expertise and customer-focused support you can trust"
    tagline="Core Strengths"
    items={[
      {
        title: '24/7 US-Based Support',
        description: 'Real people, real support. Our US-based team is always available when you need us.',
        icon: 'flat-color-icons:approval',
      },
      {
        title: 'Proactive Maintenance',
        description:
          'Prevent issues before they happen with our proactive monitoring and preventive maintenance programs.',
        icon: 'flat-color-icons:database',
      },
      {
        title: 'Scalable Solutions',
        description:
          'Grow with confidence. Our services scale with your business needs, from startups to enterprises.',
        icon: 'flat-color-icons:currency-exchange',
      },
      {
        title: 'Expert Team',
        description:
          'Certified technicians with years of experience in managed IT, networking, and telecommunications.',
        icon: 'flat-color-icons:business-contact',
      },
      {
        title: 'Predictable Pricing',
        description:
          'Transparent, predictable monthly costs eliminate surprise IT expenses and improve your bottom line.',
        icon: 'flat-color-icons:advertising',
      },
      {
        title: 'Seamless Migration',
        description:
          'Smooth transitions to new systems with minimal downtime and comprehensive training for your team.',
        icon: 'flat-color-icons:template',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Steps Widget ****************** -->

  <Steps
    title="Getting Started with Top Grade Tech"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Consultation</span>',
        description:
          "We'll meet with your team to understand your current IT infrastructure, challenges, and goals to design the perfect solution.",
        icon: 'tabler:headset',
      },
      {
        title: 'Step 2: <span class="font-medium">Solution Design</span>',
        description:
          'Our experts develop a tailored solution that addresses your specific needs with managed IT, networking, and telecom services.',
        icon: 'tabler:pencil',
      },
      {
        title: 'Step 3: <span class="font-medium">Implementation & Training</span>',
        description:
          'We handle the setup and provide comprehensive training to your staff, ensuring a smooth transition with zero disruption.',
        icon: 'tabler:school',
      },
      {
        title: 'Ready to Grow!',
        description: 'Now focus on your business while we handle your IT infrastructure with 24/7 support.',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Top Grade Tech Process',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Get answers to common questions about Top Grade Tech's managed IT, networks, and telecom solutions."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Why should I choose Top Grade Tech over other IT providers?',
        description:
          'We offer exceptional US-based support, premium hardware solutions, unrivaled reliability, and fully managed services -- all designed around the principle of reliability through simplicity.',
      },
      {
        title: 'Do you provide 24/7 support?',
        description:
          'Yes! Our US-based support team is available 24/7/365 to assist with any issues, ensuring your business stays running without interruption.',
      },
      {
        title: 'What if I currently use another IT provider?',
        description:
          'We specialize in seamless migrations from other providers. Our team will handle the transition with minimal downtime and provide comprehensive training for your staff.',
      },
      {
        title: 'How do you ensure data security and compliance?',
        description:
          'We implement enterprise-grade security measures, conduct regular monitoring, and ensure compliance with industry standards and regulations relevant to your business.',
      },
      {
        title: 'What areas do you service?',
        description:
          'We provide services throughout the United States with local support teams ready to assist businesses of all sizes.',
      },
      {
        title: 'How do I get started?',
        description:
          "Simply contact us at (855) 947-0067 (toll-free) or (719) 766-0944 (local), email info@topgradetech.com, or visit us at 2001 Oakshire Lane, Suite C, Pueblo, CO 81001. We'll schedule a consultation to discuss your needs.",
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    id="contact"
    actions={[
      {
        variant: 'primary',
        text: 'Call Us Today',
        href: 'tel:+18559470067',
      },
      {
        variant: 'secondary',
        text: 'Email Us',
        href: 'mailto:info@topgradetech.com',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to Experience<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"> Top Grade Tech Support?</span>
    </Fragment>

    <Fragment slot="subtitle">
      Let our US-based team handle your IT infrastructure so you can focus on growing your business.<br class="hidden md:inline" />Contact us today for a free consultation.
    </Fragment>
  </CallToAction>
</Layout>
