  <style is:global>
    #contact > div.relative > div.max-w-3xl {
      border-top: 1px solid rgb(203 213 225);
    }

    [data-home-scrollfx] {
      --home-fx-x: 0px;
      --home-fx-y: 24px;
      --home-fx-scale: 1;
      --home-fx-delay: 0ms;
      --home-motion-multiplier: 1;
      opacity: 1;
      filter: blur(0);
      transform: translate3d(0, 0, 0) scale(1);
      transition:
        transform 700ms cubic-bezier(0.22, 1, 0.36, 1),
        opacity 520ms ease,
        filter 520ms ease;
      transition-delay: var(--home-fx-delay);
      will-change: transform, opacity;
    }

    [data-home-scrollfx='left'] {
      --home-fx-x: -40px;
      --home-fx-y: 0px;
    }

    [data-home-scrollfx='right'] {
      --home-fx-x: 40px;
      --home-fx-y: 0px;
    }

    [data-home-scrollfx='up'] {
      --home-fx-x: 0px;
      --home-fx-y: 28px;
    }

    [data-home-scrollfx='zoom'] {
      --home-fx-x: 0px;
      --home-fx-y: 16px;
      --home-fx-scale: 0.97;
    }

    html.home-scrollfx-ready [data-home-scrollfx]:not(.is-visible) {
      opacity: 0;
      filter: blur(2px);
      transform: translate3d(
          calc(var(--home-fx-x) * var(--home-motion-multiplier)),
          calc(var(--home-fx-y) * var(--home-motion-multiplier)),
          0
        )
        scale(var(--home-fx-scale));
    }

    html.home-scrollfx-ready [data-home-scrollfx].is-visible {
      opacity: 1;
      filter: blur(0);
      transform: translate3d(0, 0, 0) scale(1);
    }

    @media (max-width: 767px) {
      [data-home-scrollfx] {
        --home-fx-y: 14px;
        --home-motion-multiplier: 0.7;
      }

      [data-home-scrollfx='left'],
      [data-home-scrollfx='right'] {
        --home-fx-x: 0px;
        --home-fx-y: 16px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      [data-home-scrollfx],
      html.home-scrollfx-ready [data-home-scrollfx],
      html.home-scrollfx-ready [data-home-scrollfx]:not(.is-visible),
      html.home-scrollfx-ready [data-home-scrollfx].is-visible {
        opacity: 1;
        filter: none;
        transform: none;
        transition: none;
      }
    }
  </style>

  <script is:inline>
    const HOME_SCROLL_FX_STATE = '__homeScrollFxState';
    const HOME_SCROLL_FX_READY_CLASS = 'home-scrollfx-ready';

    const initHomeScrollFx = () => {
      const sections = Array.from(document.querySelectorAll('[data-home-scrollfx]'));
      if (sections.length === 0) return;

      const root = document.documentElement;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) {
        root.classList.remove(HOME_SCROLL_FX_READY_CLASS);
        sections.forEach((section) => section.classList.add('is-visible'));
        return;
      }

      const existingState = window[HOME_SCROLL_FX_STATE];
      if (existingState) {
        existingState.observer?.disconnect();
      }

      const state = {
        observer: null,
      };
      window[HOME_SCROLL_FX_STATE] = state;
      root.classList.add(HOME_SCROLL_FX_READY_CLASS);

      sections.forEach((section, index) => {
        if (!(section instanceof HTMLElement)) return;
        const stagger = Math.min(index * 28, 180);
        section.style.setProperty('--home-fx-delay', `${stagger}ms`);
        section.classList.remove('is-visible');
      });

      state.observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const target = entry.target;
            if (!(target instanceof HTMLElement)) return;
            if (!entry.isIntersecting) return;
            target.classList.add('is-visible');
            state.observer?.unobserve(target);
          });
        },
        {
          threshold: 0.18,
          rootMargin: '0px 0px -10% 0px',
        }
      );

      sections.forEach((section) => {
        state.observer?.observe(section);
      });

      // Reveal content already in view after refresh, then keep it static.
      window.requestAnimationFrame(() => {
        window.requestAnimationFrame(() => {
          sections.forEach((section) => {
            if (!(section instanceof HTMLElement)) return;
            const rect = section.getBoundingClientRect();
            if (rect.top < window.innerHeight * 0.9) {
              section.classList.add('is-visible');
              state.observer?.unobserve(section);
            }
          });
        });
      });
    };

    initHomeScrollFx();
    document.addEventListener('astro:after-swap', initHomeScrollFx);
  </script>
</Layout>
