---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Top Grade Tech -- Managed IT, Security, and Communications',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Contact Us',
        href: '#contact',
      },
      { text: 'Learn more', href: '#features' },
    ]}
    image={{ src: '~/assets/images/shutterstock_345985838-optimized.jpg', alt: 'Top Grade Tech Hero Image' }}
  >
    <Fragment slot="title">
      Premier <span class="hidden xl:inline">US-Based</span>
      <span class="text-accent dark:text-white"> Customer Support</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">Top Grade Tech</span> delivers reliability through simplicity with managed IT, cybersecurity, and communications solutions.</span
      >
      <span class="block mb-1 sm:hidden font-bold text-blue-600">Top Grade Tech: Reliability Through Simplicity.</span>
      Trusted by businesses across the US for managed IT services, premium hardware solutions, and fully managed telecom services with unrivaled support.
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="Our Promise:" description="Reliability through Simplicity" />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Core Services"
    title="Everything You Need to Run Securely"
    subtitle="Managed IT, cybersecurity, and communications services designed to keep your business operating efficiently."
    items={[
      {
        title: 'Managed IT Services',
        description:
          '24/7 monitoring, proactive maintenance, patching, and endpoint management to keep your systems healthy.',
        icon: 'tabler:headset',
      },
      {
        title: 'IT Service Desk',
        description: 'Responsive support for your team, from password resets to complex technical escalations.',
        icon: 'tabler:lifebuoy',
      },
      {
        title: 'Cybersecurity',
        description:
          'Threat monitoring, endpoint protection, and security best practices that reduce risk and improve resilience.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Cloud & Microsoft 365',
        description:
          'Email, collaboration, and cloud productivity solutions that keep your team connected anywhere.',
        icon: 'tabler:phone',
      },
      {
        title: 'Video Conferencing',
        description: 'Modern conferencing and meeting tools that improve collaboration and reduce travel.',
        icon: 'tabler:video',
      },
      {
        title: 'Physical Security',
        description:
          'Video surveillance, access control, and intelligent sensors for a safer and more secure workplace.',
        icon: 'tabler:network',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Our Approach"
    title="Proactive, Documented, and Measurable"
    items={[
      {
        title: 'Monitoring and Alerting',
        description: 'We watch your critical systems 24/7 and address issues before they impact operations.',
      },
      {
        title: 'Lifecycle Management',
        description: 'Patch, update, and optimize devices on a predictable schedule.',
      },
      {
        title: 'Structured Service Desk',
        description: 'Tiered support that keeps response times fast and resolutions clear.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Top Grade Tech Solutions',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Reliability Through Simplicity</h3>
      We believe the best technology is the technology that works seamlessly, requires minimal management, and delivers maximum peace of mind.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Add-On Services',
        description: 'Backup, cloud infrastructure, and advanced security tooling that scale with your needs.',
      },
      {
        title: 'Collaboration Tools',
        description: 'Microsoft 365 and meeting platforms that reduce friction across teams.',
      },
      {
        title: 'Infrastructure and Connectivity',
        description: 'Network planning, hardware, and connectivity support built for reliability.',
      },
      {
        title: 'Security and Compliance',
        description: 'Policies, monitoring, and controls that help reduce risk and protect data.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600132806370-bf17e65e942f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2194&q=80',
      alt: 'Top Grade Tech Services',
    }}
  >
    <Fragment slot="content">Enterprise-grade solutions, simplified for your business.</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    tagline="Security Solutions"
    title="Protect People, Places, and Assets"
    items={[
      {
        title: 'Video Surveillance',
        description: 'Cloud-managed cameras with searchable footage and actionable alerts.',
      },
      {
        title: 'Access Control',
        description: 'Modern door access systems with centralized management.',
      },
      {
        title: 'Environmental Sensors',
        description: 'Real-time monitoring for safety, occupancy, and facility insights.',
      },
      {
        title: 'Mobile Surveillance',
        description: 'Rapid-deploy security options for remote sites and temporary locations.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Top Grade Tech Enterprise Solutions',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Enterprise-Grade Solutions</h3>
      Tailored IT, network, and telecom services designed for businesses that demand reliability and performance.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Features2 Widget - Service Offerings *** -->

  <Features2
    title="Who Do We Help"
    subtitle="Industry-focused solutions built for uptime, security, and continuity."
    tagline="Industries"
    columns={4}
    items={[
      {
        title: 'Hospitals & Healthcare',
        description: 'Secure systems that support patient care, compliance, and uptime.',
        icon: 'tabler:heart-rate-monitor',
      },
      {
        title: 'Education & Schools',
        description: 'Reliable networks and support for staff, students, and devices.',
        icon: 'tabler:school',
      },
      {
        title: 'Retail & Warehouse',
        description: 'Connectivity, security, and systems that keep operations moving.',
        icon: 'tabler:building-warehouse',
      },
      {
        title: 'Construction',
        description: 'Mobile-ready tech, jobsite connectivity, and secure access.',
        icon: 'tabler:crane',
      },
    ]}
  />

  <Features2
    title="Why Choose Top Grade Tech"
    subtitle="US-based support with clear processes and accountable service."
    tagline="Core Strengths"
    items={[
      {
        title: '24/7 US-Based Support',
        description: 'Real people, real support. Our US-based team is always available when you need us.',
        icon: 'flat-color-icons:approval',
      },
      {
        title: 'Proactive Monitoring',
        description: 'Continuous monitoring helps prevent outages and reduce downtime.',
        icon: 'flat-color-icons:database',
      },
      {
        title: 'Scalable Services',
        description: 'Add or adjust services as your needs evolve.',
        icon: 'flat-color-icons:currency-exchange',
      },
      {
        title: 'Expert Team',
        description: 'Certified technicians with deep experience across IT, security, and communications.',
        icon: 'flat-color-icons:business-contact',
      },
      {
        title: 'Predictable Pricing',
        description: 'Clear monthly costs and straightforward scoping.',
        icon: 'flat-color-icons:advertising',
      },
      {
        title: 'Seamless Migration',
        description: 'Onboarding plans that minimize disruption and accelerate adoption.',
        icon: 'flat-color-icons:template',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Steps Widget ****************** -->

  <Steps
    title="Getting Started with Top Grade Tech"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Discovery</span>',
        description:
          "We review your current environment and priorities to map the right solution mix.",
        icon: 'tabler:headset',
      },
      {
        title: 'Step 2: <span class="font-medium">Plan</span>',
        description:
          'We build a phased plan for managed IT, security, and communications improvements.',
        icon: 'tabler:pencil',
      },
      {
        title: 'Step 3: <span class="font-medium">Launch</span>',
        description:
          'We deploy, train your staff, and provide ongoing support.',
        icon: 'tabler:school',
      },
      {
        title: 'Ready to Grow!',
        description: 'Focus on your business while we handle day-to-day operations.',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Top Grade Tech Process',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Get answers to common questions about Top Grade Tech's managed IT, networks, and telecom solutions."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Why should I choose Top Grade Tech over other IT providers?',
        description:
          'We deliver US-based support, proactive monitoring, and a full stack of IT, security, and communications services built around reliability through simplicity.',
      },
      {
        title: 'Do you provide 24/7 support?',
        description:
          'Yes! Our US-based support team is available 24/7/365 to assist with any issues, ensuring your business stays running without interruption.',
      },
      {
        title: 'What if I currently use another IT provider?',
        description:
          'We specialize in seamless migrations from other providers. Our team will handle the transition with minimal downtime and provide comprehensive training for your staff.',
      },
      {
        title: 'How do you ensure data security and compliance?',
        description:
          'We implement enterprise-grade security measures, conduct regular monitoring, and ensure compliance with industry standards and regulations relevant to your business.',
      },
      {
        title: 'What areas do you service?',
        description:
          'We provide services throughout the United States with local support teams ready to assist businesses of all sizes.',
      },
      {
        title: 'How do I get started?',
        description:
          "Simply contact us at (855) 947-0067 (toll-free) or (719) 766-0944 (local), email info@topgradetech.com, or visit us at 2001 Oakshire Lane, Suite C, Pueblo, CO 81001. We'll schedule a consultation to discuss your needs.",
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    id="contact"
    actions={[
      {
        variant: 'primary',
        text: 'Call Us Today',
        href: 'tel:+18559470067',
      },
      {
        variant: 'secondary',
        text: 'Email Us',
        href: 'mailto:info@topgradetech.com',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to Experience<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"> Top Grade Tech Support?</span>
    </Fragment>

    <Fragment slot="subtitle">
      Let our US-based team handle your IT infrastructure so you can focus on growing your business.<br class="hidden md:inline" />Contact us today for a free consultation.
    </Fragment>
  </CallToAction>
</Layout>
