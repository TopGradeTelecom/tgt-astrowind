  <!-- CallToAction Widget *********** -->

  <div data-home-scrollfx="zoom">
    <CallToAction
      id="contact"
      actions={[
        {
          variant: 'primary',
          text: 'Call Us Today',
          href: 'tel:+18559470067',
        },
        {
          variant: 'secondary',
          text: 'Email Us',
          href: 'mailto:support@topgradetech.com',
        },
      ]}
    >
      <Fragment slot="title">
        Keep Revenue-Critical Operations<br class="block sm:hidden" /><span class="sm:whitespace-nowrap sm:ml-1">Running with Top Grade Tech</span>
      </Fragment>

      <Fragment slot="subtitle">
