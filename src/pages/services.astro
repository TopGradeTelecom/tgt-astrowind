---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Services',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Services"
    title="Managed IT, Security, and Communications"
    subtitle="A complete service stack that helps you run securely, support users quickly, and scale with confidence."
    actions={[{ variant: 'primary', text: 'Talk to an Expert', href: '/contact' }]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'Top Grade Tech Services',
    }}
  />

  <div id="it-solutions" class="scroll-mt-24"></div>

  <!-- Features2 Widget ************** -->

  <Features2
    title="Service Categories"
    subtitle="Choose what you need now and expand as your business grows."
    columns={3}
    items={[
      {
        title: 'Managed IT',
        description: 'Monitoring, patching, endpoint management, and lifecycle planning.',
        icon: 'tabler:settings',
      },
      {
        title: 'IT Service Desk',
        description: 'Responsive support with clear escalation and accountability.',
        icon: 'tabler:lifebuoy',
      },
      {
        title: 'Cybersecurity',
        description: 'Threat monitoring, endpoint protection, and security best practices.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Cloud and Microsoft 365',
        description: 'Email, collaboration, and cloud productivity solutions.',
        icon: 'tabler:cloud',
      },
      {
        title: 'Video Conferencing',
        description: 'Meeting rooms, devices, and collaboration platforms.',
        icon: 'tabler:video',
      },
      {
        title: 'Physical Security',
        description: 'Video surveillance, access control, and intelligent sensors.',
        icon: 'tabler:lock',
      },
      {
        title: 'Infrastructure and Connectivity',
        description: 'Network planning, hardware, and reliable connectivity.',
        icon: 'tabler:network',
      },
      {
        title: 'Backup and Recovery',
        description: 'Reliable backups and restore plans built for continuity.',
        icon: 'tabler:database',
      },
      {
        title: 'Project Services',
        description: 'Planning and deployment for upgrades and new initiatives.',
        icon: 'tabler:clipboard-check',
      },
    ]}
  />

  <div id="unified-communications" class="scroll-mt-24"></div>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    items={[
      {
        title: 'Discovery and Documentation',
        description: 'We document systems, risks, and priorities to create a clear plan.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'Standardized Operations',
        description: 'Consistent processes reduce downtime and improve user experience.',
        icon: 'tabler:arrows-shuffle',
      },
      {
        title: 'Measurable Outcomes',
        description: 'Service reports help you understand performance and trends.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Security by Design',
        description: 'Security is built into every layer of support and delivery.',
        icon: 'tabler:shield-lock',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1525909002-1b05e0c869d8?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=870&q=80',
      alt: 'Top Grade Tech Approach',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">How We Deliver</h3>
      We align technology to your goals with proactive support and clear accountability.
    </Fragment>
  </Content>

  <div id="security-solutions" class="scroll-mt-24"></div>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Flexible Service Bundles',
        description: 'Select only the services you need with room to grow.',
        icon: 'tabler:adjustments-horizontal',
      },
      {
        title: 'US-Based Support',
        description: 'Responsive help from people who understand your environment.',
        icon: 'tabler:headset',
      },
      {
        title: 'Predictable Costs',
        description: 'Clear monthly pricing and defined service scope.',
        icon: 'tabler:coin',
      },
      {
        title: 'Fast Onboarding',
        description: 'Smooth transition with minimal disruption.',
        icon: 'tabler:rocket',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664688-cf412ec27db2?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
      alt: 'Top Grade Tech Benefits',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Benefits</h3>
      Stability, security, and visibility without the overhead of a large internal team.
    </Fragment>
  </Content>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Request a Consultation',
        href: '/contact',
      },
    ]}
    title="Build the right service mix"
    subtitle="Tell us your goals and we will recommend a plan that fits your business."
  />
</Layout>
