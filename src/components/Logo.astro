---
import logoLight from '~/assets/images/top-grade-tech.png';
import logoDark from '~/assets/images/top-grade-tech-white.png';

const logoAlt = 'Top Grade Tech';
---

<span class="flex items-center gap-2">
  <img src={logoLight.src} alt={logoAlt} class="h-8 w-auto dark:hidden" loading="eager" decoding="async" />
  <img src={logoDark.src} alt={logoAlt} class="h-8 w-auto hidden dark:block" loading="eager" decoding="async" />
  <span class="self-center text-2xl md:text-xl font-bold text-gray-900 whitespace-nowrap dark:text-white">
    {logoAlt}
  </span>
</span>
