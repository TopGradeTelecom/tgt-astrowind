---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ToggleTheme from '~/components/common/ToggleTheme.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import Button from '~/components/ui/Button.astro';

import { getHomePermalink } from '~/utils/permalinks';
import { trimSlash } from '~/utils/permalinks';
import type { CallToAction } from '~/types';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface MenuLink extends Link {
  links?: Array<MenuLink>;
  mega?: {
    viewAllText?: string;
    viewAllHref?: string;
    sections?: Array<MenuLink>;
    tiles?: Array<{
      section: string;
      items: Array<{ title: string; description?: string; href: string }>;
    }>;
  };
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  showToggleTheme = false,
  position = 'center',
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky, dark: isDark },
    'top-0 z-40 flex-none mx-auto w-full border-b border-gray-50/0 transition-[opacity] ease-in-out',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="absolute inset-0"></div>
  <div
    class:list={[
      'relative text-default py-3 px-3 md:px-6 mx-auto w-full',
      {
        'md:flex md:justify-between': position !== 'center',
      },
      {
        'md:grid md:grid-cols-[auto_minmax(0,1fr)_auto] md:items-center': position === 'center',
      },
      {
        'max-w-7xl': !isFullWidth,
      },
    ]}
  >
    <div class:list={[{ 'mr-auto rtl:mr-0 rtl:ml-auto': position === 'right' }, 'flex justify-between']}>
      <a class="flex items-center" href={getHomePermalink()}>
        <Logo />
      </a>
      <div class="flex items-center md:hidden">
        <ToggleMenu />
      </div>
    </div>
    <nav
      class="items-center w-full hidden md:flex md:mx-5 text-default overflow-y-auto overflow-x-hidden md:overflow-y-visible md:overflow-x-auto md:min-w-0 md:justify-self-stretch"
      aria-label="Main navigation"
    >
      <ul
        class="flex flex-col md:flex-row md:self-center w-full text-xl md:text-[0.9375rem] tracking-[0.01rem] font-medium md:justify-center"
      >
        {
          links.map(({ text, href, links, mega }) => (
            <li class={links?.length ? 'dropdown' : ''}>
              {links?.length ? (
                <>
                  <button
                    type="button"
                    class="hover:text-link dark:hover:text-white px-4 py-3 flex items-center whitespace-nowrap"
                  >
                    {text}{' '}
                    <Icon name="tabler:chevron-down" class="w-3.5 h-3.5 ml-0.5 rtl:ml-0 rtl:mr-0.5 hidden md:inline" />
                  </button>
                  {mega ? (
                    <div
                      class="dropdown-menu md:backdrop-blur-md dark:md:bg-dark rounded md:absolute pl-4 md:pl-0 md:hidden font-medium md:bg-white/95 md:min-w-[680px] drop-shadow-xl"
                      data-mega
                    >
                      <div class="grid gap-6 md:grid-cols-[220px_minmax(0,1fr)] p-4 md:p-6">
                        <div class="border-b md:border-b-0 md:border-r border-gray-100 dark:border-slate-700 pb-4 md:pb-0 md:pr-4">
                          <ul class="space-y-1">
                            {mega.sections?.map(({ text: sectionText, href: sectionHref }) => (
                              <li>
                                <a
                                  class="block px-3 py-2 rounded hover:bg-gray-100 dark:hover:bg-gray-700 hover:text-link dark:hover:text-white"
                                  href={sectionHref}
                                  data-mega-section={sectionText}
                                >
                                  {sectionText}
                                </a>
                              </li>
                            ))}
                          </ul>
                          {mega.viewAllHref && (
                            <a
                              class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-link hover:underline"
                              href={mega.viewAllHref}
                            >
                              {mega.viewAllText ?? 'View All'}
                              <Icon name="tabler:arrow-up-right" class="w-4 h-4" />
                            </a>
                          )}
                        </div>
                        <div class="space-y-5">
                          {mega.tiles?.map(({ section, items }, index) => (
                            <div class:list={[{ hidden: index !== 0 }, 'space-y-3']} data-mega-panel={section}>
                              <p class="text-xs font-semibold tracking-[0.08em] text-muted uppercase">{section}</p>
                              <div class="grid gap-3 sm:grid-cols-2">
                                {items.map(({ title: itemTitle, description: itemDescription, href: itemHref }) => (
                                  <a
                                    class="block rounded-lg border border-gray-100 dark:border-slate-700 bg-white/60 dark:bg-slate-800/70 px-3 py-2 text-sm text-default hover:border-link hover:text-link transition"
                                    href={itemHref}
                                  >
                                    <span class="font-medium block">{itemTitle}</span>
                                    {itemDescription && (
                                      <span class="text-xs text-muted dark:text-slate-400 block mt-1">{itemDescription}</span>
                                    )}
                                  </a>
                                ))}
                              </div>
                            </div>
                          ))}
                        </div>
                      </div>
                    </div>
                  ) : (
                    <ul class="dropdown-menu md:backdrop-blur-md dark:md:bg-dark rounded md:absolute pl-4 md:pl-0 md:hidden font-medium md:bg-white/90 md:min-w-[200px] drop-shadow-xl">
                      {links.map(({ text: text2, href: href2 }) => (
                        <li>
                          <a
                            class:list={[
                              'first:rounded-t last:rounded-b md:hover:bg-gray-100 hover:text-link dark:hover:text-white dark:hover:bg-gray-700 py-2 px-5 block whitespace-no-wrap',
                              { 'aw-link-active': href2 === currentPath },
                            ]}
                            href={href2}
                          >
                            {text2}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </>
              ) : (
                <a
                  class:list={[
                    'hover:text-link dark:hover:text-white px-4 py-3 flex items-center whitespace-nowrap',
                    { 'aw-link-active': href === currentPath },
                  ]}
                  href={href}
                >
                  {text}
                </a>
              )}
            </li>
          ))
        }
        {showToggleTheme && (
          <li class="flex items-center px-4 py-3 md:hidden">
            <ToggleTheme iconClass="w-6 h-6" />
          </li>
        )}
      </ul>
    </nav>
    <div
      class:list={[
        { 'ml-auto rtl:ml-0 rtl:mr-auto': position === 'left' },
        'hidden md:self-center md:flex items-center md:mb-0 fixed w-full md:w-auto md:static justify-end left-0 rtl:left-auto rtl:right-0 bottom-0 p-3 md:p-0 md:justify-self-end',
      ]}
    >
      <div class="items-center flex justify-end gap-2 w-full md:w-auto">
        {showToggleTheme && (
          <span class="hidden md:inline-flex">
            <ToggleTheme iconClass="w-5 h-5 md:inline-block" />
          </span>
        )}
        {
          actions?.length ? (
            <span>
              {actions.map((btnProps) => (
                <Button {...btnProps} class="ml-2 py-2.5 px-5.5 md:px-6 font-semibold shadow-none text-sm w-auto" />
              ))}
            </span>
          ) : (
            ''
          )
        }
      </div>
    </div>
  </div>
</header>

<style is:inline>
  [data-mega-section].mega-active {
    background: rgb(243 244 246);
    color: rgb(2 61 170);
  }

  .dark [data-mega-section].mega-active {
    background: rgb(55 65 81);
    color: rgb(255 255 255);
  }
</style>

<script is:inline>
  const initMegaMenus = () => {
    const megaMenus = document.querySelectorAll('[data-mega]');
    megaMenus.forEach((menu) => {
      if (menu.dataset.megaInit === 'true') return;
      menu.dataset.megaInit = 'true';

      const sectionLinks = menu.querySelectorAll('[data-mega-section]');
      const panels = menu.querySelectorAll('[data-mega-panel]');
      if (!sectionLinks.length || !panels.length) return;

      const showPanel = (section) => {
        panels.forEach((panel) => {
          panel.classList.toggle('hidden', panel.getAttribute('data-mega-panel') !== section);
        });
        sectionLinks.forEach((link) => {
          link.classList.toggle('mega-active', link.getAttribute('data-mega-section') === section);
        });
      };

      const defaultSection = sectionLinks[0].getAttribute('data-mega-section');
      if (defaultSection) showPanel(defaultSection);

      sectionLinks.forEach((link) => {
        link.addEventListener('mouseenter', () => {
          const section = link.getAttribute('data-mega-section');
          if (section) showPanel(section);
        });
        link.addEventListener('focus', () => {
          const section = link.getAttribute('data-mega-section');
          if (section) showPanel(section);
        });
      });
    });
  };

  initMegaMenus();
  document.addEventListener('astro:after-swap', initMegaMenus);
</script>
